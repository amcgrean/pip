# Backend
ENVIRONMENT=development
APP_NAME=Beisser Internal Operations Platform
API_V1_PREFIX=/api/v1
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=INFO
SECRET_KEY=replace_with_secure_random_value
ACCESS_TOKEN_EXPIRE_MINUTES=480
ALGORITHM=HS256
DATABASE_URL=postgresql+psycopg2://beisser:beisser@db:5432/beisser_ops
CORS_ALLOWED_ORIGINS=http://localhost:5173
LOCAL_STORAGE_DIR=./data_storage
MAX_ATTACHMENT_SIZE_BYTES=10485760
MAX_IMPORT_SIZE_BYTES=5242880
ALLOWED_ATTACHMENT_EXTENSIONS=.pdf,.png,.jpg,.jpeg,.csv,.txt,.doc,.docx,.xlsx
SEED_ADMIN_EMAIL=admin@beisser-internal.com
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_ADMIN_FULL_NAME=Internal Admin

# Frontend
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Postgres
POSTGRES_DB=beisser_ops
POSTGRES_USER=beisser
POSTGRES_PASSWORD=beisser
